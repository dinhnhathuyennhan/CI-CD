  "main": "index.js",
  "scripts": {
    "lint:inline": "bash scripts/lint-inline.sh",
    "lint:spectral": "spectral lint dist/openapi-bundled.yaml --ruleset .spectral.js --verbose",
    "validate:api": "redocly lint dist/openapi-bundled.yaml",

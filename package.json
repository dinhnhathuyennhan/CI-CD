  "devDependencies": {
    "@redocly/cli": "^2.31.2",
    "@stoplight/spectral-cli": "^6.15.1",
    "swagger-ui-dist": "^5.11.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@google/generative-ai": "^0.24.1",
